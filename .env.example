# akomanga — Supabase must match Pūrākau (shared project + logins)
# Project ref: vuxeemwxdldfjybzgtxc → https://vuxeemwxdldfjybzgtxc.supabase.co
# Copy to `.env` or mirror keys from Pūrākau’s `.env` / Vercel env pull.

# Pūrākau / Pānui — defaults to same-origin path /panui (add /panui route on Akomanga when mounted).
# Legacy: separate-site Pūrākau (omit VITE_PANUI_APP_URL).
# VITE_PURAKAU_APP_URL=https://purakau.nz
# VITE_PANUI_APP_URL=http://localhost:5177

# Local one-liner: `npm run dev:with-mata` starts Mata (:5176) + shell (:5174). Full stitch: `npm run dev:ecosystem` (Maumahara :5175, Pānui :5177, Mata :5176, shell — see scripts/dev-ecosystem-all.sh).

# Header persona (Student / Teacher / Coordinator / Admin): on in `npm run dev`; for preview/production builds only, set true (UI overlay — RLS still uses your real login).
# VITE_ENABLE_DEV_PERSONA_SWITCHER=true

# Vercel: set ONLY on the Akomanga project (Dashboard → Settings → Environment Variables).
# Values are origins: https + host, no path, no trailing slash (see vercel.json).
# MATA_DEPLOYMENT_ORIGIN=https://your-mata-project.vercel.app
# MAUMAHARA_DEPLOYMENT_ORIGIN=https://your-maumahara-project.vercel.app
# PANUI_DEPLOYMENT_ORIGIN=https://your-panui-project.vercel.app
#
# On each satellite Vercel project, set VITE_APP_BASE: /mata/ | /maumahara/ | /panui/
#
# After deploy: AKOMANGA_URL=https://your-akomanga.vercel.app npm run smoke:ecosystem

# Cursor hooks — optional (see .cursor/hooks.json): auto-reminder after `git push`; set ECOSYSTEM_AUTO_GH_WORKFLOW=1 to dispatch GitHub Actions Ecosystem smoke via `gh` (needs `gh auth login`).
# ECOSYSTEM_AKOMANGA_URL=https://your-akomanga.vercel.app
# ECOSYSTEM_AUTO_GH_WORKFLOW=1

# Akomanga `vite` dev: proxies /mata, /maumahara, /panui using MATA_DEV_PROXY_TARGET / MAUMAHARA_DEV_PROXY_TARGET / PANUI_DEV_PROXY_TARGET only (defaults :5176, :5175, :5177). Do not use VITE_*_APP_URL here — those are for browser links only; using the Akomanga URL would proxy to itself and return 500.
# For same-origin Join class + Supabase session: leave VITE_MATA_APP_URL unset; set VITE_APP_BASE=/mata/ on Mata (see ECOSYSTEM.md).
# MATA_DEV_PROXY_TARGET=http://localhost:5176
# MAUMAHARA_DEV_PROXY_TARGET=http://localhost:5175
# PANUI_DEV_PROXY_TARGET=http://localhost:5177

# Optional — local/dev satellite app overrides (separate origin from Akomanga; you must sign in on that app too unless using same-origin proxy above).
# Production should usually use same-domain rewrites:
#   /mata/* -> Mata app
#   /maumahara/* -> Maumahara app
# If you set VITE_MATA_APP_URL to http://localhost:5176, dev builds use `/classroom` on Mata when its `base` is `/`.
# Do not set it to the Akomanga dev URL (e.g. :5174) — use unset + `/mata` proxy or the real Mata port.
# VITE_MATA_APP_URL=http://localhost:5176
# VITE_MAUMAHARA_APP_URL=http://localhost:5175
# VITE_PANUI_APP_URL=http://localhost:5177

# Supabase (browser) — Dashboard → Settings → API → URL + anon public
VITE_SUPABASE_URL=https://vuxeemwxdldfjybzgtxc.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Edge Function `hr-invite-learner` (Dashboard → Edge Functions → Secrets), not Vite:
# SUPABASE_SERVICE_ROLE_KEY — required for invites
# INVITE_REDIRECT_TO — optional full URL after accepting invite (e.g. https://yourapp.com/login)

# Drizzle Kit / drizzle-kit — direct Postgres (not exposed to the browser)
# Supabase Dashboard → Settings → Database → URI, or build from db.<ref>.supabase.co
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.vuxeemwxdldfjybzgtxc.supabase.co:5432/postgres

# OpenAI API Key (for GPT suggestions - third-wave tagging)
# Get from: https://platform.openai.com/api-keys — or copy from Pūrākau `.env` into `.env.local` (gitignored)
VITE_OPENAI_API_KEY=sk-...

# AI4Thai — one key for G2P (`fillMissingG2pFromAi4thai`), th2en, TLex+/LexTo+/Longan/tpos
# Optional: or set localStorage smartSubs_ai4thai_apiKey on the page. https://aiforthai.in.th/
VITE_AI4THAI_API_KEY=

# Google Cloud TTS — required on Supabase Edge for `synthesize-thai-tts` when pipeline runs audio.
# R2 upload secrets are only on the `upload-r2-audio` function (not this file). See SmarterSubs
# `supabase/functions/upload-r2-audio/index.ts` and GET `run-pipeline-preview` → meta.envHints.r2Upload.
VITE_GOOGLE_TTS_API_KEY=

# —— Cloudflare R2 (same as Pūrākau; used by Edge Functions + CLI, not Vite client) ——
# Account Id — Cloudflare dashboard
# CLOUDFLARE_ACCOUNT_ID=
# R2 S3 API credentials (R2 → Manage R2 API Tokens)
# CLOUDFLARE_S3_ACCESS_KEY_ID=
# CLOUDFLARE_S3_SECRET_ACCESS_KEY=
# Bucket + public URL — also set as Supabase Edge secrets where functions expect them
# CLOUDFLARE_R2_BUCKET_NAME=
# CLOUDFLARE_R2_PUBLIC_URL=
